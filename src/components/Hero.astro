---
// Hero — 2 columnas: texto informativo + carrusel de productos
import { getProductsForHero } from '../data/products';

const carouselProducts = getProductsForHero(3);
---

<section class="hero" id="hero">
  <div class="hero__bg"></div>

  <div class="hero__container container">
    <!-- Columna izquierda: Texto -->
    <div class="hero__content">
      <span class="hero__badge">🌟 Nueva Temporada 2026</span>
      <h1 class="hero__title">
        Descubre <span class="hero__highlight">Tu Mundo Shop</span>
      </h1>
      <p class="hero__text">
        Somos tu tienda de confianza para productos tecnológicos seleccionados
        cuidadosamente. Trabajamos con las mejores marcas para traerte <strong>calidad
        garantizada</strong>, los <strong>precios más competitivos</strong> y una
        <strong>atención personalizada</strong> que marca la diferencia.
      </p>
      <p class="hero__text hero__text--secondary">
        Desde lo esencial hasta lo extraordinario, cada producto en nuestro catálogo
        ha sido elegido para superar tus expectativas. Explora nuestras categorías
        y encuentra lo que necesitas con la confianza de quien sabe que eligió bien.
      </p>
      <div class="hero__actions">
        <a href="#premium" class="btn btn-primary btn-lg">
          Ver Productos
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#info" class="btn btn-secondary btn-lg">
          Conócenos
        </a>
      </div>
      <div class="hero__features">
        <div class="hero__feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Pago 100% seguro</span>
        </div>
        <div class="hero__feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Envíos a todo el país</span>
        </div>
        <div class="hero__feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Atención personalizada</span>
        </div>
      </div>
    </div>

    <!-- Columna derecha: Carrusel -->
    <div class="hero__carousel" aria-label="Productos destacados">
      <div class="hero__carousel-track" id="carousel-track">
        {carouselProducts.map((product, index) => (
          <a
            href={`/productos/${product.slug}`}
            class:list={['hero__carousel-slide', { 'hero__carousel-slide--active': index === 0 }]}
            aria-label={product.name}
          >
            <div class="hero__carousel-card">
              <div class="hero__carousel-image-wrapper">
                <img
                  src={product.image}
                  alt={product.name}
                  class="hero__carousel-image"
                  width="600"
                  height="400"
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <div class="hero__carousel-category">
                  {product.category === 'premium' ? '⭐ PREMIUM' : product.category === 'exclusivos' ? '🔥 EXCLUSIVO' : '🆕 NUEVO'}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Dots de navegación -->
      <div class="hero__carousel-dots" id="carousel-dots">
        {carouselProducts.map((_, index) => (
          <button
            class:list={['hero__carousel-dot', { 'hero__carousel-dot--active': index === 0 }]}
            aria-label={`Ir al producto ${index + 1}`}
            data-index={index}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const slides = document.querySelectorAll('#carousel-track .hero__carousel-slide');
    const dots = document.querySelectorAll('#carousel-dots .hero__carousel-dot');
    if (!slides.length) return;

    let current = Array.from(slides).findIndex(s => s.classList.contains('hero__carousel-slide--active'));
    if (current === -1) current = 0;
    const total = slides.length;

    function goTo(index) {
      slides.forEach((s, i) => {
        s.classList.toggle('hero__carousel-slide--active', i === index);
        dots[i]?.classList.toggle('hero__carousel-dot--active', i === index);
      });
      current = index;
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', function() { goTo(i); });
    });

    let interval = setInterval(function() {
      goTo((current + 1) % total);
    }, 4500);

    const carousel = document.getElementById('carousel-track')?.closest('.hero__carousel');
    if (carousel) {
      carousel.addEventListener('mouseenter', function() { clearInterval(interval); interval = null; });
      carousel.addEventListener('mouseleave', function() {
        if (interval) clearInterval(interval);
        interval = setInterval(function() {
          goTo((current + 1) % total);
        }, 4500);
      });
    }
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
    background: var(--color-primary);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(238, 193, 43, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(68, 169, 84, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(238, 193, 43, 0.04) 0%, transparent 50%);
  }

  .hero__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-lg);
  }

  @media (min-width: 768px) {
    .hero__container {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }

  /* ===== COLUMNA IZQUIERDA ===== */
  .hero__content {
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero__badge {
    display: inline-block;
    padding: 6px 18px;
    background: rgba(238, 193, 43, 0.15);
    border: 1px solid rgba(238, 193, 43, 0.25);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-secondary);
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-size: clamp(2rem, 4.5vw, 3.8rem);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hero__highlight {
    background: linear-gradient(135deg, var(--color-secondary), #f5d654);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__text {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero__text strong {
    color: var(--color-secondary);
    font-weight: 600;
  }

  .hero__text--secondary {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.55);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .hero__features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .hero__feature {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
  }

  .hero__feature svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* ===== COLUMNA DERECHA — CARRUSEL ===== */
  .hero__carousel {
    position: relative;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    opacity: 1 !important;
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.15s;
  }

  .hero__carousel-track {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2.8;
  }

  .hero__carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateX(30px) scale(0.95);
    transition: opacity 0.5s ease, transform 0.5s ease, visibility 0.5s ease;
    pointer-events: none;
  }

  .hero__carousel-slide--active {
    opacity: 1;
    visibility: visible;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  .hero__carousel-card {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease;
  }

  .hero__carousel-card:hover {
    border-color: rgba(238, 193, 43, 0.3);
  }

  .hero__carousel-image-wrapper {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .hero__carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__carousel-category {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    padding: 4px 14px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-secondary);
    letter-spacing: 0.02em;
  }

  /* Dots */
  .hero__carousel-dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: var(--space-lg);
  }

  .hero__carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .hero__carousel-dot--active {
    background: var(--color-secondary);
    border-color: var(--color-secondary);
    box-shadow: 0 0 12px rgba(238, 193, 43, 0.4);
  }

  .hero__carousel-dot:hover {
    border-color: var(--color-secondary);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 767px) {
    .hero {
      min-height: auto;
      padding-bottom: var(--space-2xl);
    }
    .hero__container {
      padding: var(--space-xl) var(--space-md);
      gap: var(--space-xl);
    }
    .hero__actions {
      flex-direction: column;
    }
    .hero__actions .btn {
      width: 100%;
    }
    .hero__carousel {
      max-width: 100%;
    }
    .hero__carousel-track {
      aspect-ratio: 3 / 3.2;
    }
    .hero__text {
      max-width: 100%;
    }
    .hero__title {
      font-size: clamp(1.8rem, 6vw, 2.5rem);
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    .hero__carousel {
      max-width: 380px;
    }
    .hero__carousel-track {
      aspect-ratio: 3 / 3;
    }
  }
</style>
