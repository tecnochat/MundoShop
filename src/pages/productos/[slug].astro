---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { products, getAllSlugs } from '../../data/products';

export async function getStaticPaths() {
  const slugs = getAllSlugs();
  return slugs.map(slug => {
    const product = products.find(p => p.slug === slug);
    return {
      params: { slug },
      props: { product },
    };
  });
}

const { product } = Astro.props;
const related = products.filter(p => p.category === product.category && p.id !== product.id).slice(0, 3);

const productImage = product.image;

const catNames = {
  premium: { label: 'Premium', emoji: '⭐' },
  estandar: { label: 'Estándar', emoji: '✅' },
  nuevos: { label: 'Nuevos', emoji: '🆕' },
  exclusivos: { label: 'Exclusivos', emoji: '🔥' },
};
const catInfo = catNames[product.category] || { label: product.category, emoji: '' };

const siteUrl = process.env.RAILWAY_PUBLIC_DOMAIN
  ? `https://${process.env.RAILWAY_PUBLIC_DOMAIN}`
  : 'https://mundo-shop.up.railway.app';
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: siteUrl + productImage,
  offers: {
    '@type': 'Offer',
    price: product.price.replace(/[$.]/g, '').replace(',', '.'),
    priceCurrency: 'ARS',
    availability: 'https://schema.org/InStock',
    url: siteUrl + '/productos/' + product.slug,
  },
  brand: {
    '@type': 'Brand',
    name: 'Tu Mundo Shop',
  },
};
---

<Layout
  title={product.name}
  description={product.highlight}
  image={productImage}
  ogType="product"
  schema={productSchema}
>
  <Header />
  <main class="product-detail-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li><a href={"/#" + product.category}>{catInfo.emoji} {catInfo.label}</a></li>
          <li aria-current="page">{product.name}</li>
        </ol>
      </nav>

      <div class="product-detail">
        <div class="product-detail__image-wrapper">
          <img
            src={productImage}
            alt={product.name}
            class="product-detail__image"
            width="600"
            height="400"
            decoding="async"
          />
          <span class="product-detail__category-badge">{catInfo.emoji} {catInfo.label}</span>
        </div>

        <div class="product-detail__info">
          <h1 class="product-detail__title">{product.name}</h1>

          <div class="product-detail__price">
            <span class="product-detail__price-label">Precio:</span>
            <span class="product-detail__price-value">{product.price}</span>
          </div>

          <div class="product-detail__description">
            <h3>Descripción</h3>
            <p>{product.description}</p>
          </div>

          <div class="product-detail__features">
            <h3>Características destacadas</h3>
            <ul>
              {product.features.map(f => <li>{f}</li>)}
            </ul>
          </div>

          <div class="product-detail__actions">
            <WhatsAppButton phone={product.whatsapp} productName={product.name} />
            <a href="/" class="btn btn-outline">← Seguir viendo</a>
          </div>

          <div class="product-detail__shipping-note">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <span>Envíos a todo el país. Consulta tiempos en la sección <a href="/#envios">Envíos</a>.</span>
          </div>
        </div>
      </div>

      {related.length > 0 && (
        <section class="related-products">
          <h2 class="related-products__title">También te puede interesar</h2>
          <div class="related-products__grid">
            {related.map(rp => {
              const rpImage = rp.image;
              return (
                <a href={"/productos/" + rp.slug} class="related-card">
                  <img src={rpImage} alt={rp.name} loading="lazy" width="300" height="200" class="related-card__img" />
                  <div class="related-card__body">
                    <h3 class="related-card__title">{rp.name}</h3>
                    <span class="related-card__price">{rp.price}</span>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .product-detail-page {
    padding-top: calc(var(--header-height) + var(--space-lg));
    padding-bottom: var(--space-3xl);
    min-height: 100vh;
  }
  .breadcrumb {
    margin-bottom: var(--space-xl);
    font-size: var(--text-sm);
  }
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
  }
  .breadcrumb li {
    color: var(--color-gray-500);
  }
  .breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-xs);
    color: var(--color-gray-300);
  }
  .breadcrumb a {
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }
  .breadcrumb a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }
  .breadcrumb li[aria-current] {
    color: var(--color-gray-800);
    font-weight: 600;
  }
  .product-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }
  @media (min-width: 768px) {
    .product-detail {
      grid-template-columns: 1fr 1fr;
    }
  }
  .product-detail__image-wrapper {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-gray-100);
    aspect-ratio: 3 / 2;
  }
  .product-detail__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-detail__category-badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    box-shadow: var(--shadow-sm);
  }
  .product-detail__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .product-detail__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    line-height: 1.15;
  }
  .product-detail__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-gray-50);
    border-radius: var(--radius-lg);
  }
  .product-detail__price-label {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }
  .product-detail__price-value {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
  }
  .product-detail__description h3,
  .product-detail__features h3 {
    font-size: var(--text-base);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }
  .product-detail__description p {
    color: var(--color-gray-600);
    line-height: 1.7;
  }
  .product-detail__features ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .product-detail__features li {
    background: var(--color-gray-50);
    border: 1px solid var(--color-gray-200);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-gray-700);
  }
  .product-detail__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
  .product-detail__actions .btn {
    flex: 1;
    min-width: 200px;
  }
  .product-detail__actions .btn-whatsapp {
    font-size: var(--text-base);
    padding: 1rem 2rem;
  }
  .product-detail__shipping-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-gray-50);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }
  .product-detail__shipping-note svg {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 2px;
  }
  .product-detail__shipping-note a {
    color: var(--color-primary);
    font-weight: 600;
  }
  .product-detail__shipping-note a:hover {
    text-decoration: underline;
  }
  .related-products {
    border-top: 1px solid var(--color-gray-200);
    padding-top: var(--space-2xl);
  }
  .related-products__title {
    text-align: center;
    margin-bottom: var(--space-xl);
    font-size: var(--text-2xl);
  }
  .related-products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }
  .related-card {
    display: block;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }
  .related-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--color-primary-light);
  }
  .related-card__img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }
  .related-card__body {
    padding: var(--space-md);
  }
  .related-card__title {
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .related-card__price {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-primary);
  }
</style>
